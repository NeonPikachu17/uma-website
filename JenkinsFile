pipeline {
    agent any

    environment {
        SERVERS = 'msbernabe@20.83.153.128 msbernabe@172.208.67.151'
        DOCROOT = '/var/www/html'
        APP_SRC = './'
    }

    stages {
        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Deploy') {
            steps {
                // Jenkins automatically injects the SSH key from UI credentials here!
                sshagent(credentials: ['webservers-ssh-key']) {
                    sh '''
                        set -eu
                        SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
                        for HOST in ${SERVERS}; do
                            echo "=== Deploying to ${HOST}:${DOCROOT} ==="
                            rsync -az --delete -e "ssh ${SSH_OPTS}" --rsync-path="sudo rsync" \
                                --exclude '.git' --exclude 'Jenkinsfile' \
                                "${APP_SRC}" "${HOST}:${DOCROOT}/"
                            ssh ${SSH_OPTS} "${HOST}" "sudo systemctl reload apache2"
                            echo "=== ${HOST} updated ==="
                        done
                    '''
                }
            }
        }
    }
}
